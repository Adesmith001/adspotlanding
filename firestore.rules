rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidPublicRole(role) {
      return role in ['owner', 'advertiser'];
    }

    function isViewIncrementOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
             request.resource.data.views == resource.data.views + 1;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles (for displaying owner info, etc.)
      allow read: if isAuthenticated();
      // Users can only create their own profile with a public role.
      allow create: if isOwner(userId) &&
                      isValidPublicRole(request.resource.data.role);
      // Role is immutable after account creation.
      allow update: if isOwner(userId) &&
                      request.resource.data.role == resource.data.role;
      allow delete: if isOwner(userId);
    }
    
    // Listings collection
    match /listings/{listingId} {
      // Anyone can read listings (public marketplace)
      allow read: if true;
      // Only authenticated users can create listings
      // And the ownerId must match the authenticated user
      allow create: if isAuthenticated() && 
                      request.resource.data.ownerId == request.auth.uid;
      // Only the owner can update or delete their listing
      allow update, delete: if isAuthenticated() && 
                              resource.data.ownerId == request.auth.uid;
    }
    
    // Billboards collection (same rules as listings)
    match /billboards/{billboardId} {
      // Anyone can read billboards (public marketplace)
      allow read: if true;
      // Only authenticated users can create billboards
      // And the ownerId must match the authenticated user
      allow create: if isAuthenticated() && 
                      request.resource.data.ownerId == request.auth.uid;
      // Only the owner can update or delete their billboard
      allow update: if (isAuthenticated() && resource.data.ownerId == request.auth.uid) ||
                      isViewIncrementOnly();
      allow delete: if isAuthenticated() && 
                      resource.data.ownerId == request.auth.uid;
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      // Anyone can read reviews
      allow read: if true;
      // Only authenticated users can create reviews
      allow create: if isAuthenticated() &&
                      request.resource.data.advertiserId == request.auth.uid;
      // Users can update/delete their own reviews
      allow update, delete: if isAuthenticated() &&
                              resource.data.advertiserId == request.auth.uid;
    }
    
    // Favorites collection
    match /favorites/{favoriteId} {
      // Users can only read their own favorites
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
      // Users can create their own favorites
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      // Users can delete their own favorites
      allow update, delete: if isAuthenticated() &&
                              resource.data.userId == request.auth.uid;
    }
    
    // Bookings collection
    match /bookings/{bookingId} {
      // Only involved parties (advertiser or owner) can read
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.advertiserId || 
         request.auth.uid == resource.data.ownerId);
      // Only authenticated users can create bookings
      allow create: if isAuthenticated() &&
                      request.resource.data.advertiserId == request.auth.uid;
      // Both parties can update (for status changes, etc.)
      allow update: if isAuthenticated() && 
        (request.auth.uid == resource.data.advertiserId || 
         request.auth.uid == resource.data.ownerId);
      // Only the owner can delete bookings
      allow delete: if isAuthenticated() && 
                      request.auth.uid == resource.data.ownerId;
    }

    // Conversations collection
    match /conversations/{conversationId} {
      // Only participants can read their conversations
      allow read: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      // Authenticated users can create conversations where they are a participant
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;
      // Participants can update (e.g., mark as read, update lastMessage)
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;
      // Authenticated users can create notifications for others (e.g., messages, bookings)
      allow create: if isAuthenticated();
      // Users can update their own notifications (e.g., mark as read)
      allow update: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() &&
        request.auth.uid == resource.data.userId;
    }

    // Legacy top-level messages collection (kept for backwards compatibility)
    match /messages/{messageId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.senderId || 
         request.auth.uid == resource.data.receiverId);
      allow create: if isAuthenticated() &&
                      request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && 
        (request.auth.uid == resource.data.advertiserId || 
         request.auth.uid == resource.data.ownerId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Public booking windows used for date availability checks
    match /billboardAvailability/{bookingId} {
      allow read: if true;
      allow create, update: if isAuthenticated() &&
        exists(/databases/$(database)/documents/bookings/$(bookingId)) &&
        (request.auth.uid == get(/databases/$(database)/documents/bookings/$(bookingId)).data.advertiserId ||
         request.auth.uid == get(/databases/$(database)/documents/bookings/$(bookingId)).data.ownerId) &&
        request.resource.data.bookingId == bookingId &&
        request.resource.data.billboardId == get(/databases/$(database)/documents/bookings/$(bookingId)).data.billboardId &&
        request.resource.data.advertiserId == get(/databases/$(database)/documents/bookings/$(bookingId)).data.advertiserId &&
        request.resource.data.ownerId == get(/databases/$(database)/documents/bookings/$(bookingId)).data.ownerId &&
        request.resource.data.startDate == get(/databases/$(database)/documents/bookings/$(bookingId)).data.startDate &&
        request.resource.data.endDate == get(/databases/$(database)/documents/bookings/$(bookingId)).data.endDate &&
        request.resource.data.status in ['confirmed', 'active'] &&
        request.resource.data.paymentStatus in ['pending', 'paid'];
      allow delete: if isAuthenticated() &&
        exists(/databases/$(database)/documents/bookings/$(bookingId)) &&
        (request.auth.uid == get(/databases/$(database)/documents/bookings/$(bookingId)).data.advertiserId ||
         request.auth.uid == get(/databases/$(database)/documents/bookings/$(bookingId)).data.ownerId);
    }
  }
}
